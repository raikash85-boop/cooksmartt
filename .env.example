# ==========================================
# CookSmart Environment Variables
# Copy this file to .env and fill in values
# ==========================================

# PostgreSQL Database (get from Neon.tech - free tier)
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/cooksmart?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/cooksmart?sslmode=require"

# JWT Secret (generate a random 32+ char string)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-here"

# WebSocket Server Port (for local development only)
WS_PORT=4000
